# Ghosted Environment Configuration
# Copy this file to .env and fill in the values

# Django settings
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
USE_SQLITE=False
DB_NAME=ghosted
DB_USER=postgres
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cache settings
CACHE_TTL_SECONDS=120
PAGINATION_COUNT_CACHE_TIMEOUT=120

# Resume session settings
RESUME_SESSION_TTL_SECONDS=3600
RESUME_MAX_FILE_BYTES=5242880
RESUME_MAX_PAGES=4

# Optional: Logo.dev API key for better company logo coverage
# VITE_LOGO_DEV_PUBLISHABLE_KEY=your-logo-dev-key
